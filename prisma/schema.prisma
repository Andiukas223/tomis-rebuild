generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies        Company[]
  equipment        Equipment[]
  generatedReports GeneratedReport[]
  manufacturers    Manufacturer[]
  products         Product[]
  users            User[]
  hospitals        Hospital[]
  serviceCases     ServiceCase[]
  systems          System[]
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  email          String   @unique
  passwordHash   String
  fullName       String
  role           String
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  generatedReports        GeneratedReport[]      @relation("GeneratedReportCreatedBy")
  assignedServiceCases ServiceCase[] @relation("ServiceCaseAssignee")
  serviceAssignmentEvents ServiceAssignmentEvent[] @relation("ServiceAssignmentChangedBy")
  serviceNotes            ServiceNote[] @relation("ServiceNoteAuthor")
  assignedServiceTasks    ServiceTask[] @relation("ServiceTaskAssignee")
  changedServiceTaskEvents ServiceTaskEvent[] @relation("ServiceTaskEventChangedBy")
  uploadedServiceAttachments ServiceAttachment[] @relation("ServiceAttachmentUploader")
  sessions             Session[]
}

model Session {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revokedAt   DateTime?
  userAgent   String?
  ipAddress   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id             String   @id @default(cuid())
  name           String
  code           String?
  vatCode        String?
  city           String?
  country        String?
  addressLine1   String?
  addressLine2   String?
  website        String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Manufacturer {
  id             String   @id @default(cuid())
  name           String
  code           String?
  country        String?
  website        String?
  supportEmail   String?
  supportPhone   String?
  productFocus   String?
  serviceNotes   String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  equipment    Equipment[]
  products     Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Equipment {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  model          String?
  serialNumber   String?
  category       String?
  status         String
  manufacturerId String
  organizationId String
  systemId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  serviceCases ServiceCase[]
  system       System?      @relation(fields: [systemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([manufacturerId])
  @@index([systemId])
  @@index([status])
}

model Product {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  sku            String?
  category       String?
  status         String
  manufacturerId String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([manufacturerId])
  @@index([status])
}

model Hospital {
  id             String   @id @default(cuid())
  name           String
  code           String?
  city           String?
  country        String?
  addressLine1   String?
  addressLine2   String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  serviceRegion  String?
  serviceNotes   String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  systems      System[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model System {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  serialNumber   String?
  hospitalId     String
  status         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  hospital     Hospital     @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  equipment    Equipment[]
  serviceCases ServiceCase[]

  @@index([organizationId])
  @@index([hospitalId])
  @@index([status])
}

model ServiceCase {
  id             String   @id @default(cuid())
  code           String   @unique
  title          String
  summary        String?
  workPerformed  String?
  resolution     String?
  followUpRequired Boolean @default(false)
  followUpActions String?
  status         String
  priority       String
  scheduledAt    DateTime?
  completedAt    DateTime?
  systemId       String
  equipmentId    String?
  assignedUserId String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  system       System         @relation(fields: [systemId], references: [id], onDelete: Restrict)
  equipment    Equipment?     @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  assignedUser User?          @relation("ServiceCaseAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  attachments  ServiceAttachment[]
  assignmentEvents ServiceAssignmentEvent[]
  notes        ServiceNote[]
  tasks        ServiceTask[]

  @@index([organizationId])
  @@index([systemId])
  @@index([equipmentId])
  @@index([assignedUserId])
  @@index([status])
  @@index([priority])
  @@index([scheduledAt])
}

model ServiceAssignmentEvent {
  id                 String   @id @default(cuid())
  serviceCaseId      String
  changedById        String?
  previousAssigneeId String?
  previousAssigneeName String?
  newAssigneeId      String?
  newAssigneeName    String?
  createdAt          DateTime @default(now())

  serviceCase ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Cascade)
  changedBy   User?       @relation("ServiceAssignmentChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([serviceCaseId])
  @@index([changedById])
  @@index([createdAt])
}

model ServiceTask {
  id            String   @id @default(cuid())
  title         String
  notes         String?
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  sortOrder     Int      @default(0)
  dueAt         DateTime?
  serviceCaseId String
  assignedUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  serviceCase   ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Cascade)
  assignedUser  User?       @relation("ServiceTaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  events        ServiceTaskEvent[]

  @@index([serviceCaseId])
  @@index([sortOrder])
  @@index([dueAt])
  @@index([assignedUserId])
}

model ServiceTaskEvent {
  id                 String   @id @default(cuid())
  serviceTaskId      String
  changedById        String?
  eventType          String
  previousTitle      String?
  newTitle           String?
  previousNotes      String?
  newNotes           String?
  previousDueAt      DateTime?
  newDueAt           DateTime?
  previousCompleted  Boolean?
  newCompleted       Boolean?
  previousAssigneeId String?
  previousAssigneeName String?
  newAssigneeId      String?
  newAssigneeName    String?
  createdAt          DateTime @default(now())

  serviceTask ServiceTask @relation(fields: [serviceTaskId], references: [id], onDelete: Cascade)
  changedBy   User?       @relation("ServiceTaskEventChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([serviceTaskId])
  @@index([changedById])
  @@index([createdAt])
}

model ServiceAttachment {
  id            String   @id @default(cuid())
  fileName      String
  storageKey    String   @unique
  contentType   String
  sizeBytes     Int
  serviceCaseId String
  uploadedById  String?
  createdAt     DateTime @default(now())

  serviceCase ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Cascade)
  uploadedBy  User?       @relation("ServiceAttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([serviceCaseId])
  @@index([uploadedById])
  @@index([createdAt])
}

model ServiceNote {
  id            String   @id @default(cuid())
  body          String
  serviceCaseId String
  authorId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  serviceCase ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Cascade)
  author      User?       @relation("ServiceNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([serviceCaseId])
  @@index([authorId])
  @@index([createdAt])
}

model GeneratedReport {
  id             String   @id @default(cuid())
  reportType     String
  title          String
  notes          String?
  isPinned       Boolean  @default(false)
  workflowStatus String   @default("Draft")
  label          String?
  scopeLabel     String
  dateWindowLabel String
  filters        Json
  snapshot       Json
  organizationId String
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy    User?        @relation("GeneratedReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdById])
  @@index([createdAt])
  @@index([reportType])
}
